# Secret pour la signature des tokens JWT (à changer impérativement en production)
JWT_SECRET=changez-moi-avec-une-valeur-secrete-aleatoire

# Secret pour les cookies de session
COOKIE_SECRET=changez-moi-aussi-avec-une-valeur-secrete

# Port du serveur (par défaut : 3000)
PORT=3000

# Environnement (development ou production)
NODE_ENV=development

# Supabase (identifiants côté client, à configurer dans config.js)
# Récupérez ces valeurs depuis : https://supabase.com/dashboard > Settings > API
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre-cle-anon-publique
